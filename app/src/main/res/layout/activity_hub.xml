<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/hub"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══════════════════════════════════
         HEADER
    ══════════════════════════════════ -->

    <TextView
        android:id="@+id/tvEyebrow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/hub_eyebrow"
        android:textSize="@dimen/text_eyebrow"
        android:textColor="@color/primary"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:paddingStart="@dimen/spacing_medium"
        android:paddingTop="@dimen/spacing_large"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnToggleTheme"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/hub_title"
        android:textSize="@dimen/text_title"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:letterSpacing="-0.02"
        android:lineSpacingMultiplier="1.05"
        android:paddingStart="@dimen/spacing_medium"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvEyebrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnToggleTheme"/>

    <ImageButton
        android:id="@+id/btnToggleTheme"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:background="@drawable/bg_theme_btn"
        android:src="@drawable/ic_moon"
        android:padding="8dp"
        app:tint="@color/textPrimary"
        app:layout_constraintTop_toTopOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══════════════════════════════════
         HERO CARD (módulo mais acessado)
    ══════════════════════════════════ -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHero"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:layout_marginTop="@dimen/spacing_large"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toTopOf="@id/cardMini1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintHeight_min="180dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_card"
            android:padding="@dimen/spacing_medium">

            <!-- Badge "mais acessado" — visível só após 1º acesso (controle via código) -->
            <TextView
                android:id="@+id/tvHeroBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hub_most_used"
                android:textSize="9sp"
                android:textColor="@color/textPrimary"
                android:letterSpacing="0.06"
                android:textAllCaps="true"
                android:background="@drawable/bg_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <ImageView
                android:id="@+id/ivHeroIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="@color/onPrimary"
                app:layout_constraintBottom_toTopOf="@id/tvHeroTitle"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvHeroTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/basket_module_name"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:letterSpacing="-0.01"
                android:lineSpacingMultiplier="1.1"
                app:layout_constraintBottom_toTopOf="@id/tvHeroDesc"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvHeroDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/basket_desc"
                android:textSize="12sp"
                android:textColor="@color/textPrimary"
                android:alpha="0.6"
                android:lineSpacingMultiplier="1.4"
                app:layout_constraintBottom_toTopOf="@id/tvHeroCta"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:id="@+id/tvHeroCta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hub_open_module"
                android:textSize="11sp"
                android:textColor="#93C5FD"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════
         MINI CARD 1
    ══════════════════════════════════ -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMini1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toTopOf="@id/tvFooter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cardMini2"
        app:layout_constraintHeight_percent="0.22">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_mini_card_green"
            android:padding="@dimen/spacing_medium">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/mini_card_1_stroke"/>

            <TextView
                android:id="@+id/tvMini1Title"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="@string/calculator_name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:layout_marginTop="@dimen/spacing_small"
                android:lineSpacingMultiplier="1.1"
                android:gravity="bottom"/>

            <TextView
                android:id="@+id/tvMini1Desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/calculator_desc"
                android:textSize="10sp"
                android:textColor="@color/textPrimary"
                android:alpha="0.7"
                android:layout_marginTop="3dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════
         MINI CARD 2
    ══════════════════════════════════ -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMini2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:layout_marginTop="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="@id/cardMini1"
        app:layout_constraintBottom_toBottomOf="@id/cardMini1"
        app:layout_constraintStart_toEndOf="@id/cardMini1"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_mini_card_ambar"
            android:padding="@dimen/spacing_medium">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_add"
                app:tint="#673AB7"/>

            <TextView
                android:id="@+id/tvMini2Title"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="@string/third_app_name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:layout_marginTop="@dimen/spacing_small"
                android:lineSpacingMultiplier="1.1"
                android:gravity="bottom"/>

            <TextView
                android:id="@+id/tvMini2Desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/third_app_desc"
                android:textSize="10sp"
                android:textColor="@color/textPrimary"
                android:alpha="0.7"
                android:layout_marginTop="3dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════
         FOOTER
    ══════════════════════════════════ -->

    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/hub_title"
        android:textSize="9sp"
        android:textColor="@color/textSecondary"
        android:alpha="0.3"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        android:layout_marginBottom="@dimen/spacing_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>